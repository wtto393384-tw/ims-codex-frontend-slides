flowchart TD
    Start["使用者登入系統"] --> Dashboard["進入儀表板"]
    Dashboard --> MasterData["建立主檔資料"]

    MasterData --> Category["產品分類管理"]
    MasterData --> Product["商品管理"]
    MasterData --> Supplier["廠商管理"]
    MasterData --> Customer["客戶管理"]

    Category --> Product
    Product --> Purchase["建立進貨單"]
    Supplier --> Purchase
    Product --> Sale["建立銷貨單"]
    Customer --> Sale

    Purchase --> PurchaseItems["選擇多筆商品\n輸入數量與單價"]
    PurchaseItems --> AddStock["系統增加商品庫存"]
    AddStock --> PurchaseMovement["寫入庫存異動\n進貨入庫"]

    Sale --> SaleItems["選擇多筆商品\n輸入數量與單價"]
    SaleItems --> CheckStock{"庫存是否足夠？"}
    CheckStock -- "否" --> BlockSale["阻擋銷貨單建立\n提示庫存不足"]
    CheckStock -- "是" --> DeductStock["系統扣除商品庫存"]
    DeductStock --> SaleMovement["寫入庫存異動\n銷貨出庫"]

    PurchaseMovement --> Inventory["庫存查詢"]
    SaleMovement --> Inventory
    Inventory --> LowStock["低庫存提醒"]
    Inventory --> MovementQuery["庫存異動紀錄查詢"]
    MovementQuery --> Reports["Excel 報表匯出"]
    LowStock --> Reports
    Reports --> Summary["IMS_總報表.xlsx\n多工作表彙整"]
