flowchart LR
    User["使用者 / 管理者"] --> Browser["Chrome / Web Browser"]
    Browser --> UI["Bootstrap 前端頁面\n表單、表格、篩選、按鈕"]
    UI --> Flask["Flask Web App\n路由、驗證、商業邏輯"]

    Flask --> Auth["登入與權限控制\nSession / Admin"]
    Flask --> Master["主檔管理\n商品、分類、廠商、客戶"]
    Flask --> Trade["交易流程\n進貨單、銷貨單"]
    Flask --> Stock["庫存邏輯\n加庫存、扣庫存、低庫存"]
    Flask --> Reports["報表模組\nopenpyxl 產生 Excel"]

    Auth --> SQLite[("SQLite Database\ninstance/ims.sqlite3")]
    Master --> SQLite
    Trade --> SQLite
    Stock --> SQLite
    Reports --> SQLite

    Reports --> Excel["Excel 檔案\nIMS_總報表.xlsx\n個別報表.xlsx"]

    subgraph Dev["開發與驗證"]
        VSCode["VS Code"] --> Code["app.py / templates / static / schema.sql"]
